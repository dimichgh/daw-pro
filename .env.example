# Copy to .env and fill in. Never commit .env.
# AI text/reasoning (lyrics, naming, theory) — at least one required for AI features
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ACE-Step-1.5 local song/vocal generation sidecar (primary engine, M6)
ACE_STEP_URL=http://127.0.0.1:8001

# Suno — dormant cloud fallback; no official public API as of 2026-07-05
SUNO_API_KEY=
SUNO_API_BASE=

# GPT Image (UI asset generation) uses OPENAI_API_KEY
OPENAI_IMAGE_MODEL=gpt-image-2

# DAW control plane
DAW_CONTROL_PORT=17600
